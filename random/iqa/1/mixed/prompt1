best_srcc = -1.0 epochs_no_improve = 0 history = {'train_loss': [], 'val_loss':
[], 'val_plcc': [], 'val_srcc': []}

FREEZE_EPOCHS = 2 # Train only the head for the first 2 epochs

print("[*] Starting Training Loop...")

for epoch in range(EPOCHS): # --- GRADUAL UNFREEZING LOGIC --- if epoch == 0:
print("[!] Phase 1: Backbones FROZEN. Warming up Regression Head...")
model.freeze_backbones() elif epoch == FREEZE_EPOCHS: print("[!] Phase 2:
Backbones UNFROZEN. End-to-end fine-tuning begins...")
model.unfreeze_backbones() # Optional but highly recommended: Lower the learning
rate for fine-tuning for param_group in optimizer.param_groups:
param_group['lr'] = LEARNING_RATE * 0.1

# --- TRAINING PHASE ---
model.train()
running_loss = 0.0

for img_global, img_local, targets in train_loader:
    img_global, img_local, targets = img_global.to(DEVICE), img_local.to(DEVICE), targets.to(DEVICE)
    
    optimizer.zero_grad()
    
    with torch.autocast(device_type=DEVICE.type):
        predictions = model(img_global, img_local)
        loss = criterion(predictions, targets)
        
    scaler.scale(loss).backward()
    scaler.step(optimizer)
    scaler.update()
    
    running_loss += loss.item()
    
avg_train_loss = running_loss / len(train_loader)

# --- VALIDATION PHASE ---
model.eval()
val_loss = 0.0
all_preds, all_targets = [], []

with torch.no_grad():
    for img_global, img_local, targets in test_loader:
        img_global, img_local, targets = img_global.to(DEVICE), img_local.to(DEVICE), targets.to(DEVICE)
        
        with torch.autocast(device_type=DEVICE.type):
            predictions = model(img_global, img_local)
            loss = criterion(predictions, targets)
            
        val_loss += loss.item()
        all_preds.extend(predictions.cpu().numpy())
        all_targets.extend(targets.cpu().numpy())
        
avg_val_loss = val_loss / len(test_loader)
plcc, _ = pearsonr(all_preds, all_targets)
srcc, _ = spearmanr(all_preds, all_targets)

history['train_loss'].append(avg_train_loss)
history['val_loss'].append(avg_val_loss)
history['val_plcc'].append(plcc)
history['val_srcc'].append(srcc)

print(f"Epoch {epoch+1:02d}/{EPOCHS} | Train Loss: {avg_train_loss:.2f} | Val Loss: {avg_val_loss:.2f} | PLCC: {plcc:.4f} | SRCC: {srcc:.4f}")

# --- EARLY STOPPING & SAVING ---
if srcc > best_srcc:
    best_srcc = srcc
    epochs_no_improve = 0
    torch.save(model.state_dict(), 'best_iqa_model.pth')
else:
    epochs_no_improve += 1
    if epochs_no_improve >= PATIENCE:
        print(f"\n[!] Early Stopping triggered!")
        break

print(f"\n[*] Training Complete. Loading best model (SRCC: {best_srcc:.4f})")
model.load_state_dict(torch.load('best_iqa_model.pth'))

