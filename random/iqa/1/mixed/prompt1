MODULE 4: DECOUPLED DUAL-STREAM RESNET50 (DEEPER HEAD + FREEZING)

=====================================================================

class DualStreamResNet50(nn.Module): def init(self): super(DualStreamResNet50,
self).init()

    resnet_global = models.resnet50(weights=models.ResNet50_Weights.DEFAULT)
    resnet_local = models.resnet50(weights=models.ResNet50_Weights.DEFAULT)
    
    self.extractor_global = nn.Sequential(*list(resnet_global.children())[:-1])
    self.extractor_local = nn.Sequential(*list(resnet_local.children())[:-1])
    
    # UPGRADED: Deeper, more stable regression head with BatchNorm
    self.regression_head = nn.Sequential(
        nn.Linear(2048 * 2, 1024),
        nn.BatchNorm1d(1024),
        nn.ReLU(),
        nn.Dropout(0.5),
        
        nn.Linear(1024, 256),
        nn.BatchNorm1d(256),
        nn.ReLU(),
        nn.Dropout(0.4),
        
        nn.Linear(256, 1)
    )

def forward(self, x_global, x_local):
    feat_global = self.extractor_global(x_global).flatten(1)
    feat_local = self.extractor_local(x_local).flatten(1) 
    
    fused_features = torch.cat((feat_global, feat_local), dim=1) 
    return self.regression_head(fused_features).squeeze(1)

# NEW: Methods to handle Gradual Unfreezing
def freeze_backbones(self):
    for param in self.extractor_global.parameters():
        param.requires_grad = False
    for param in self.extractor_local.parameters():
        param.requires_grad = False

def unfreeze_backbones(self):
    for param in self.extractor_global.parameters():
        param.requires_grad = True
    for param in self.extractor_local.parameters():
        param.requires_grad = True

model = DualStreamResNet50().to(DEVICE)

