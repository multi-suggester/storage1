class DualStreamIQADataset(Dataset): def init(self, image_paths, scores,
transform_global, transform_local): self.image_paths = image_paths self.scores =
scores self.transform_global = transform_global self.transform_local =
transform_local

def __len__(self):
    return len(self.image_paths)

def __getitem__(self, idx):
    image = cv2.imread(self.image_paths[idx])
    image = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)
    
    img_global = self.transform_global(image)
    img_local = self.transform_local(image)
    score = torch.tensor(self.scores[idx], dtype=torch.float32)

    return img_global, img_local, score

Global Transform (Shared between Train and Test)

transform_global = transforms.Compose([ transforms.ToPILImage(),
transforms.Resize((224, 224)), transforms.ToTensor(),
transforms.Normalize(mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225]) ])

Local Transform (TRAIN) - Uses RandomCrop for Data Augmentation

transform_local_train = transforms.Compose([ transforms.ToPILImage(),
transforms.RandomCrop(224), transforms.ToTensor(),
