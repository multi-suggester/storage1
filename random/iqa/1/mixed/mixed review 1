def batch_plcc_loss(preds: torch.Tensor, targets: torch.Tensor) -> torch.Tensor:
    """[4.5] Differentiable PLCC loss: returns (1 - PLCC) over the batch.
    Unlike SRCC, Pearson correlation has a closed-form gradient, so we can
    directly backprop through it.  Scaling by PLCC_WEIGHT keeps it from
    dominating the SmoothL1 term.
    """
    vx = preds  - preds.mean()
    vy = targets - targets.mean()
    num = (vx * vy).sum()
    den = torch.sqrt((vx ** 2).sum() * (vy ** 2).sum()) + 1e-8
    return 1.0 - num / den


class CombinedIQALoss(nn.Module):
    """[3] SmoothL1 weighted by annotation confidence (1/SD),
    [4.5] plus a PLCC regularisation term.
    """
    def __init__(self, beta: float = 1.0, plcc_weight: float = 0.1):
        super().__init__()
        self.beta        = beta
        self.plcc_weight = plcc_weight

    def forward(self,
                preds:      torch.Tensor,
                targets:    torch.Tensor,
                sd_weights: torch.Tensor) -> torch.Tensor:
        # Per-element SmoothL1, scaled by confidence weight
        per_elem = F.smooth_l1_loss(preds, targets, reduction='none', beta=self.beta)
        smooth_l1 = (per_elem * sd_weights).mean()

        # PLCC regularisation — encourages correct global ranking within the batch
        plcc_term = batch_plcc_loss(preds, targets)

        return smooth_l1 + self.plcc_weight * plcc_term


criterion = CombinedIQALoss(beta=1.0, plcc_weight=PLCC_WEIGHT)
optimizer = optim.AdamW(model.parameters(), lr=LEARNING_RATE, weight_decay=1e-4)
scaler    = torch.amp.GradScaler(DEVICE.type)
scheduler = None   # initialised after unfreeze

# =====================================================================
# MODULE 6: TRAINING LOOP
# =====================================================================
best_srcc      = -1.0
epochs_no_improve = 0
history = {'train_loss': [], 'val_loss': [], 'val_plcc': [], 'val_srcc': []}

print('[*] Starting training...\n')

for epoch in range(EPOCHS):

    # ── Phase transitions ────────────────────────────────────────────
    if epoch == 0:
        print('[!] Phase 1 – backbones FROZEN, warming up head...')
        model.freeze_backbones()

    elif epoch == FREEZE_EPOCHS:
        print('[!] Phase 2 – backbones UNFROZEN, end-to-end fine-tuning...')
        model.unfreeze_backbones()
        for pg in optimizer.param_groups:
            pg['lr'] = LEARNING_RATE * 0.1
        scheduler = optim.lr_scheduler.CosineAnnealingLR(
            optimizer,
            T_max=EPOCHS - FREEZE_EPOCHS,
            eta_min=1e-7,
        )

    # ── Train ────────────────────────────────────────────────────────
    model.train()
    running_loss = 0.0

    for img_g, img_l, targets, sd_w in train_loader:
        img_g, img_l = img_g.to(DEVICE), img_l.to(DEVICE)
        targets, sd_w = targets.to(DEVICE), sd_w.to(DEVICE)

        optimizer.zero_grad()
        with torch.autocast(device_type=DEVICE.type):
            preds = model(img_g, img_l)
            loss  = criterion(preds, targets, sd_w)

        scaler.scale(loss).backward()
        scaler.unscale_(optimizer)
        torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)
        scaler.step(optimizer)
        scaler.update()
        running_loss += loss.item()

    if scheduler is not None:
        scheduler.step()

    avg_train_loss = running_loss / len(train_loader)

    # ── Validate (on val set, not test) ──────────────────────────────
    model.eval()
    val_loss_sum = 0.0
    all_preds, all_targets = [], []

    with torch.no_grad():
        for img_g, img_l, targets, sd_w in val_loader:
            img_g, img_l = img_g.to(DEVICE), img_l.to(DEVICE)
            targets, sd_w = targets.to(DEVICE), sd_w.to(DEVICE)
            with torch.autocast(device_type=DEVICE.type):
                preds = model(img_g, img_l)
                loss  = criterion(preds, targets, sd_w)
            val_loss_sum += loss.item()
            all_preds.extend(preds.cpu().numpy())
            all_targets.extend(targets.cpu().numpy())

    avg_val_loss = val_loss_sum / len(val_loader)
    plcc, _ = pearsonr(all_preds, all_targets)
    srcc, _ = spearmanr(all_preds, all_targets)
    current_lr = optimizer.param_groups[0]['lr']

    history['train_loss'].append(avg_train_loss)
    history['val_loss'].append(avg_val_loss)
    history['val_plcc'].append(plcc)
    history['val_srcc'].append(srcc)

    print(f'Epoch {epoch+1:03d}/{EPOCHS} | '
          f'Train: {avg_train_loss:.3f} | Val: {avg_val_loss:.3f} | '
          f'PLCC: {plcc:.4f} | SRCC: {srcc:.4f} | LR: {current_lr:.2e}')

    # ── Early stopping (based on val SRCC) ───────────────────────────
    if srcc > best_srcc:
        best_srcc = srcc
        epochs_no_improve = 0
        torch.save(model.state_dict(), f'best_iqa_{STREAM_MODE}.pth')
        print(f'  ↑ New best SRCC: {best_srcc:.4f} — model saved.')
    else:
        epochs_no_improve += 1
        if epochs_no_improve >= PATIENCE:
            print(f'\n[!] Early stopping at epoch {epoch+1}')
            break

print(f'\n[*] Training complete.  Best val SRCC: {best_srcc:.4f}')
model.load_state_dict(torch.load(f'best_iqa_{STREAM_MODE}.pth', map_location=DEVICE))

# =====================================================================
# MODULE 7: FINAL TEST EVALUATION
# =====================================================================
model.eval()
test_preds, test_targets_list = [], []

with torch.no_grad():
    for img_g, img_l, targets, sd_w in test_loader:
        img_g, img_l = img_g.to(DEVICE), img_l.to(DEVICE)
        with torch.autocast(device_type=DEVICE.type):
            preds = model(img_g, img_l)
        test_preds.extend(preds.cpu().numpy())
        test_targets_list.extend(targets.numpy())

test_preds   = np.array(test_preds)
test_targets = np.array(test_targets_list)

plcc_test, _ = pearsonr(test_preds, test_targets)
srcc_test, _ = spearmanr(test_preds, test_targets)
mae_test      = np.mean(np.abs(test_preds - test_targets))
rmse_test     = np.sqrt(np.mean((test_preds - test_targets) ** 2))

print('\n' + '='*50)
print(f'  FINAL TEST RESULTS  [{STREAM_MODE.upper()}]')
print('='*50)
