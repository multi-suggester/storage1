class DualStreamResNet50(nn.Module):
    def __init__(self, mode: str = 'dual'):
        super().__init__()
        self.mode = mode

        resnet_g = models.resnet50(weights=models.ResNet50_Weights.DEFAULT)
        self.extractor_global = nn.Sequential(*list(resnet_g.children())[:-1])

        if mode != 'global_only':
            resnet_l = models.resnet50(weights=models.ResNet50_Weights.DEFAULT)
            self.extractor_local = nn.Sequential(*list(resnet_l.children())[:-1])

        in_features = 2048 * 2 if mode == 'dual' else 2048

        self.regression_head = nn.Sequential(
            nn.Linear(in_features, 1024),
            nn.BatchNorm1d(1024),
            nn.ReLU(),
            nn.Dropout(0.3),    # [1] was 0.5

            nn.Linear(1024, 256),
            nn.BatchNorm1d(256),
            nn.ReLU(),
            nn.Dropout(0.2),    # [1] was 0.4

            nn.Linear(256, 1),
        )

    def forward(self, x_global: torch.Tensor, x_local: torch.Tensor) -> torch.Tensor:
        if self.mode == 'global_only':
            feat = self.extractor_global(x_global).flatten(1)

        elif self.mode == 'local_only':
            B, N, C, H, W = x_local.shape
            feat = self.extractor_local(x_local.view(B * N, C, H, W)).flatten(1)
            feat = feat.view(B, N, -1).mean(dim=1)         # average 5 crops

        else:  # dual
            feat_g = self.extractor_global(x_global).flatten(1)
            B, N, C, H, W = x_local.shape
            feat_l = self.extractor_local(x_local.view(B * N, C, H, W)).flatten(1)
            feat_l = feat_l.view(B, N, -1).mean(dim=1)    # average 5 crops
            feat = torch.cat((feat_g, feat_l), dim=1)

        return self.regression_head(feat).squeeze(1)

    def freeze_backbones(self):
        for p in self.extractor_global.parameters():
            p.requires_grad = False
        if hasattr(self, 'extractor_local'):
            for p in self.extractor_local.parameters():
                p.requires_grad = False

    def unfreeze_backbones(self):
        for p in self.extractor_global.parameters():
            p.requires_grad = True
        if hasattr(self, 'extractor_local'):
            for p in self.extractor_local.parameters():
                p.requires_grad = True


