def sd_to_weights(sds: list) -> list:
    """[3] Convert per-image SD to confidence weights.
    Lower SD  → raters agreed  → higher weight (model should learn this more strongly).
    Higher SD → raters disagreed → lower weight (annotation is noisy).
    Normalised so the mean weight = 1 (keeps loss magnitude stable).
    """
    arr = np.array(sds, dtype=np.float32)
    w = 1.0 / (arr + 1e-8)
    return (w / w.mean()).tolist()

train_weights = sd_to_weights(train_sds)
