# =====================================================================
class DualStreamIQADataset(Dataset):
    def __init__(self, image_paths, scores, sd_weights,
                 transform_global, mode: str = 'dual'):
        self.image_paths    = image_paths
        self.scores         = scores
        self.sd_weights     = sd_weights
        self.transform_global = transform_global
        self.mode           = mode
        self.five_crop      = transforms.FiveCrop(224)
        self.to_tensor      = transforms.ToTensor()
        self.normalize      = transforms.Normalize(
            mean=[0.485, 0.456, 0.406], std=[0.229, 0.224, 0.225]
        )

    def __len__(self):
        return len(self.image_paths)

    def _five_crop_tensor(self, pil_img: Image.Image) -> torch.Tensor:
        """Returns shape (5, 3, 224, 224)."""
        w, h = pil_img.size
        if min(w, h) < 224:                         # guard against tiny images
            scale = 224 / min(w, h) + 0.01
            pil_img = pil_img.resize((int(w * scale), int(h * scale)), Image.BILINEAR)
        crops = self.five_crop(pil_img)             # tuple of 5 PIL images
        return torch.stack([self.normalize(self.to_tensor(c)) for c in crops])

    def __getitem__(self, idx):
        image_bgr = cv2.imread(self.image_paths[idx])
        image_rgb = cv2.cvtColor(image_bgr, cv2.COLOR_BGR2RGB)

        img_global = self.transform_global(image_rgb)

        if self.mode != 'global_only':
            pil_image = Image.fromarray(image_rgb)
            img_local = self._five_crop_tensor(pil_image)  # (5, 3, 224, 224)
        else:
            img_local = torch.zeros(5, 3, 224, 224)        # unused dummy

        score     = torch.tensor(self.scores[idx],    dtype=torch.float32)
        sd_weight = torch.tensor(self.sd_weights[idx], dtype=torch.float32)

        return img_global, img_local, score, sd_weight


